{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "$schema": { "type": "string" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "lastMigration": { "type": ["string", "null"] },
    "migrationsCount": { "type": "integer" },
    "tables": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    }
  },
  "required": ["generatedAt", "tables"]
}
